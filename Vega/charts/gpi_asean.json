{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Asean Countries Average GPI",
        "fontSize": 18,
        "subtitleFontSize": 12
    },
    "width": "container",
    "height": 300,
    "data": {
        "url": "../data/gpi_asean.csv",
        "format": {
            "type": "csv"
        }
    },
    "mark": {
        "type": "bar",
        "size": 20
    },
    "encoding": {
        "x": {
            "field": "Country",
            "type": "nominal",
            "sort": {
                "field": "avg_gpi",
                "order": "ascending"
            },
            "axis": {
                "labelAngle": 0,
                "title": "Country (ASEAN)"
            }
        },
        "y": {
            "field": "avg_gpi",
            "type": "quantitative",
            "axis": {
                "title": "Average GPI Score"
            }
        },
        "color": {
            "condition": {
                "test": "datum.Country === 'Malaysia'",
                "value": "#1b7f3b"
            },
            "value": "#bdbdbd"
        },
        "tooltip": [
            {
                "field": "Country",
                "type": "nominal",
                "title": "Country"
            },
            {
                "field": "avg_gpi",
                "type": "quantitative",
                "title": "Avg GPI Score",
                "format": ".3f"
            }
        ]
    }
}