{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
        "url": "../data/srs_crime_by_stateyear.csv",
        "format": {
            "type": "csv"
        }
    },
    "vconcat": [
        {
            "width": 820,
            "height": 250,
            "transform": [
                {
                    "filter": {
                        "param": "brush"
                    }
                }
            ],
            "mark": {
                "type": "line",
                "point": true
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "temporal",
                    "title": "Year",
                    "axis": {
                        "format": "%Y",
                        "tickCount": "year"
                    }
                },
                "y": {
                    "field": "crimes",
                    "type": "quantitative",
                    "title": "Crime Count"
                },
                "color": {
                    "field": "type",
                    "type": "nominal",
                    "title": "Crime Type"
                },
                "tooltip": [
                    {
                        "field": "year",
                        "type": "temporal"
                    },
                    {
                        "field": "type",
                        "type": "nominal"
                    },
                    {
                        "field": "crimes",
                        "type": "quantitative"
                    }
                ]
            }
        },
        {
            "width": 820,
            "height": 120,
            "params": [
                {
                    "name": "brush",
                    "select": {
                        "type": "interval",
                        "encodings": [
                            "x"
                        ]
                    }
                }
            ],
            "transform": [
                {
                    "aggregate": [
                        {
                            "op": "sum",
                            "field": "crimes",
                            "as": "total_crime"
                        }
                    ],
                    "groupby": [
                        "year"
                    ]
                }
            ],
            "mark": {
                "type": "area",
                "opacity": 0.6
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "temporal",
                    "title": "Year",
                    "axis": {
                        "format": "%Y",
                        "tickCount": "year"
                    }
                },
                "y": {
                    "field": "total_crime",
                    "type": "quantitative",
                    "title": "Total Murder & Rape Crime"
                },
                "tooltip": [
                    {
                        "field": "year",
                        "type": "temporal"
                    },
                    {
                        "field": "total_crime",
                        "type": "quantitative"
                    }
                ]
            }
        }
    ]
}