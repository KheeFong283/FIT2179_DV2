{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Max Crime Type by State",
    "fontSize": 18
  },

  "width": "container",
  "height": 350,

  "projection": {
    "type": "mercator",
    "center": [109.5, 4.5],
    "scale": 2500
  },

  "data": {
    "url": "../data/crime_dominate_each_state.csv",
    "format": {"type": "csv"}
  },

  "transform": [
    {
      "lookup": "state",
      "from": {
        "data": {
          "values": [
            {"state":"Johor","lat":1.89,"lon":103.5},
            {"state": "Kedah", "lat": 6.0, "lon": 100.7},
            {"state": "Kelantan", "lat": 5.3, "lon": 102.0},
            {"state": "Melaka", "lat": 2.3, "lon": 102.3},
            {"state": "Negeri Sembilan", "lat": 2.8, "lon": 102.2},
            {"state": "Pahang", "lat": 3.8, "lon": 102.5},
            {"state": "Perak", "lat": 4.8, "lon": 101.0},
            {"state": "Perlis", "lat": 6.5, "lon": 100.2},
            {"state": "Pulau Pinang", "lat": 5.4, "lon": 100.4},
            {"state": "Sabah", "lat": 5.3, "lon": 117.0},
            {"state": "Sarawak", "lat": 2.5, "lon": 113.0},
            {"state": "Selangor", "lat": 3.3, "lon": 101.5},
            {"state": "Terengganu", "lat": 5.0, "lon": 103.0},
            {"state": "W.P. Kuala Lumpur", "lat": 3.15, "lon": 101.7}
          ]
        },
        "key": "state",
        "fields": ["lat", "lon"]
      }
    },
    {
      "calculate": "datum.type == 'theft_vehicle_motorcycle' ? 'Motorcycle Theft' : 'Other Theft'",
      "as": "crime_label"
    }
  ],

  "layer": [
    {
        "data": {
            "sphere": true
        },
        "mark": {
            "type": "geoshape",
            "fill": "#cfe8ff"
        }
    },
    {
        "data": {
            "url": "../data/output.topojson",
            "format": {
                "type": "topojson",
                "feature": "ne_10m_admin_0_countries"
            }
        },
        "mark": {
            "type": "geoshape",
            "fill": "#eeeeee",
            "stroke": "#aaaaaa",
            "strokeWidth": 0.5
        }
    },
    {
        "data": {
            "url": "../data/output.topojson",
            "format": {
                "type": "topojson",
                "feature": "ne_10m_graticules_1"
            }
        },
        "mark": {
            "type": "geoshape",
            "stroke": "#cccccc",
            "strokeWidth": 0.5
        }
    },
    {
        "data": {
            "url": "../data/output.topojson",
            "format": {
                "type": "topojson",
                "feature": "malaysia.state"
            }
        },
        "mark": {
            "type": "geoshape",
            "fill": "#e4c307",
            "stroke": "#666",
            "strokeWidth": 1
        }
    },
    {
        "mark": {
            "type": "circle",
            "filled": true,
            "opacity": 0.9,
            "stroke": "white",
            "strokeWidth": 0.5
        },
        "encoding": {
            "longitude": {
                "field": "lon",
                "type": "quantitative"
            },
            "latitude": {
                "field": "lat",
                "type": "quantitative"
            },
            "size": {
                "field": "crimes",
                "type": "quantitative",
                "legend": {
                    "title": "Total Crimes"
                }
            },
            "color": {
                "field": "crime_label",
                "type": "nominal",
                "scale": {
                    "domain": [
                        "Motorcycle Theft",
                        "Other Theft"
                    ],
                    "range": [
                        "#1f77b4",
                        "#d62728"
                    ]
                },
                "legend": {
                    "title": "Crime Type"
                }
            },
            "tooltip": [
                {
                    "field": "state",
                    "title": "State"
                },
                {
                    "field": "type",
                    "title": "Crime Type"
                },
                {
                    "field": "crimes",
                    "title": "Total Crimes",
                    "format": ","
                }
            ]
        }
    },

    {
        "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": "bold",
            "dy": -10
        },
        "encoding": {
            "longitude": {
                "field": "lon",
                "type": "quantitative"
            },
            "latitude": {
                "field": "lat",
                "type": "quantitative"
            },
            "text": {
                "field": "state",
                "type": "nominal"
            },
            "color": {
                "value": "black"
            }
        }
    }
]
}