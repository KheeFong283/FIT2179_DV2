{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total Crimes by State in Malaysia",
    "fontSize": 18
  },
  "width": "container",
  "height": 350,
  "projection": {
    "type": "mercator",
    "center": [
      109.5,
      4.5
    ],
    "scale": 2500
  },
  "layer": [
    {
      "data": {
        "sphere": true
      },
      "mark": {
        "type": "geoshape",
        "fill": "#cfe8ff"
      }
    },
    {
      "data": {
        "url": "https://github.com/KheeFong283/FIT2179_DV2/blob/main/data/map.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_0_countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eeeeee",
        "stroke": "#aaaaaa",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://github.com/KheeFong283/FIT2179_DV2/blob/main/data/map.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_graticules_1"
        }
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#cccccc",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://github.com/KheeFong283/FIT2179_DV2/blob/main/data/map.topojson",
        "format": {
          "type": "topojson",
          "feature": "malaysia.state"
        }
      },
      "transform": [
        {
          "calculate": "indexof(datum.properties.name, 'WP K Lumpur') >= 0 ? 'W.P. Kuala Lumpur' : datum.properties.name",
          "as": "state_fixed"
        },
        {
          "lookup": "state_fixed",
          "from": {
            "data": {
              "url": "https://github.com/KheeFong283/FIT2179_DV2/blob/main/data/crime_trend_by_state.csv",
              "format": {
                "type": "csv"
              }
            },
            "key": "state",
            "fields": [
              "crimes"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "condition": {
            "test": "datum.crimes == null",
            "value": "lightgray"
          },
          "field": "crimes",
          "type": "quantitative",
          "scale": {
            "scheme": "reds"
          },
          "legend": {
            "title": "Total Crimes"
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "crimes",
            "type": "quantitative",
            "format": ","
          }
        ]
      }
    },

    {
      "data": {
        "url": "../data/crime_by_state.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "lookup": "state",
          "from": {
            "data": {
              "values": [
                {"state": "Johor", "lat": 1.6, "lon": 103.7},
                {"state": "Kedah", "lat": 6.0, "lon": 100.7},
                {"state": "Kelantan", "lat": 5.3, "lon": 102.0},
                {"state": "Melaka", "lat": 2.0, "lon": 102.3},
                {"state": "Negeri Sembilan", "lat": 2.5, "lon": 102.2},
                {"state": "Pahang", "lat": 3.8, "lon": 102.5},
                {"state": "Perak", "lat": 4.8, "lon": 101.0},
                {"state": "Perlis", "lat": 6.3, "lon": 100.2},
                {"state": "Pulau Pinang", "lat": 5.4, "lon": 100.4},
                {"state": "Sabah", "lat": 5.3, "lon": 117.0},
                {"state": "Sarawak", "lat": 2.5, "lon": 113.0},
                {"state": "Selangor", "lat": 3.3, "lon": 101.5},
                {"state": "Terengganu", "lat": 5.0, "lon": 103.0},
                {"state": "W.P. Kuala Lumpur", "lat": 3.0, "lon": 101.7}
          ]
        },
        "key": "state",
        "fields": [
          "lat",
          "lon"
        ]
      }
    }
  ],
  "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": "bold",
            "dy": -10
        },
  "encoding": {
    "longitude": {
      "field": "lon",
      "type": "quantitative"
    },
    "latitude": {
      "field": "lat",
      "type": "quantitative"
    },
    "text": {
      "field": "state",
      "type": "nominal"
    },
    "color": {
      "value": "black"
    }
  }
}
]
}
