{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Crime Ranking By State Over Time",
        "fontSize": 18,
        "subtitleFontSize": 12
    },
    "width": "container",
    "height": 400,
    "data": {
        "url": "https://raw.githubusercontent.com/KheeFong283/FIT2179_DV2/refs/heads/main/data/crime_trend_by_state.csv",
        "format": {
            "type": "csv"
        }
    },
    "transform": [
        {
            "calculate": "toNumber(datum.crimes)",
            "as": "crimes_num"
        },
        {
            "window": [
                {
                    "op": "rank",
                    "as": "rank"
                }
            ],
            "groupby": [
                "year"
            ],
            "sort": [
                {
                    "field": "crimes_num",
                    "order": "descending"
                }
            ]
        }
    ],
    "mark": {
        "type": "line",
        "point": true
    },
    "encoding": {
        "x": {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
        },
        "y": {
            "field": "rank",
            "type": "ordinal",
            "title": "Crime Rank (1 = highest)"
        },
        "color": {
            "field": "state",
            "type": "nominal",
            "title": "State",
            "scale": {
                "range": [
                    "#0072B2",
                    "#E69F00",
                    "#CC79A7",
                    "#56B4E9",
                    "#F0E442",
                    "#D55E00",
                    "#009E73",
                    "#332288",
                    "#AA4499",
                    "#6699CC",
                    "#6F4E37",
                    "#999933",
                    "#44AA99",
                    "#888888"
                ]
            }
        },
        "opacity": {
            "condition": {
                "test": "indexof(['Selangor', 'Perlis'], datum.state) >= 0",
                "value": 2
            },
            "value": 0.5
        },
        "size": {
            "condition": {
                "test": "indexof(['Selangor', 'Perlis'], datum.state) >= 0",
                "value": 7
            },
            "value": 3
        },
        "tooltip": [
            {
                "field": "state",
                "type": "nominal",
                "title": "State"
            },
            {
                "field": "year",
                "type": "ordinal",
                "title": "Year"
            },
            {
                "field": "crimes_num",
                "type": "quantitative",
                "title": "Crimes",
                "format": ","
            },
            {
                "field": "rank",
                "type": "ordinal",
                "title": "Rank"
            }
        ]
    }
}