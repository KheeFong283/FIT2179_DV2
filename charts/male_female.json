{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Male vs Female Inmates in Malaysia",
        "fontSize": 18
    },
    "width": "container",
    "height": 400,
    "data": {
        "url": "https://raw.githubusercontent.com/KheeFong283/FIT2179_DV2/refs/heads/main/data/male_female.csv",
        "format": {
            "type": "csv"
        }
    },
    "transform": [
        {
            "aggregate": [
                {
                    "op": "sum",
                    "field": "prisoners",
                    "as": "total_prisoners"
                }
            ],
            "groupby": [
                "sex"
            ]
        },
        {
            "calculate": " datum.sex === 'male' ? 'Male' : datum.sex === 'female' ? 'Female' : datum.sex",
            "as": "sex_renamed"
        }
    ],
    "layer": [
        {
            "mark": {
                "type": "arc",
                "innerRadius": 60
            },
            "encoding": {
                "theta": {
                    "field": "total_prisoners",
                    "type": "quantitative"
                },
                "color": {
                    "field": "sex_renamed",
                    "type": "nominal",
                    "title": "Sex",
                    "scale": {
                        "range": [
                            "#ff69b4",
                            "#1f77b4"
                        ]
                    }
                },
                "tooltip": [
                    {
                        "field": "sex_renamed",
                        "type": "nominal",
                        "title": "Sex"
                    },
                    {
                        "field": "total_prisoners",
                        "type": "quantitative",
                        "title": "Total prisoners"
                    }
                ]
            }
        },
        {
            "data": {
                "values": [
                    { "label": "89.42%", "x": 320, "y": 170, "x2": 100, "y2": 170, "color": "#1f77b4" },
                    { "label": "10.58%", "x": 530, "y": 50, "x2": 700, "y2": 170, "color": "#ff69b4" }
                ]
            },

            "layer": [
                {
                "mark": {
                    "type": "rule",
                    "opacity": 0.3
                },
                "encoding": {
                    "x": {
                        "field": "x",
                        "type": "quantitative",
                        "scale": null,
                        "axis": null
                    },
                    "y": {
                        "field": "y",
                        "type": "quantitative",
                        "scale": null,
                        "axis": null
                    },
                    "x2": {
                        "field": "x2"
                    },
                    "y2": {
                        "field": "y2"
                    }
                }
                },
                {
                "mark": {
                    "type": "text",
                    "baseline": "line-bottom",
                    "align": "left",
                    "fontSize": 20
                },
                "encoding": {
                    "x": {
                    "field": "x2",
                    "scale": null,
                    "axis": null
                    },
                    "y": {
                    "field": "y2",
                    "scale": null,
                    "axis": null
                    },
                    "text": { "field": "label" },
                    "color": { "field": "color", "type": "nominal", "scale": null }
                }
                }
            ]
        }
    ]
}