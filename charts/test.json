{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Malaysia Crimes by Type",
        "fontSize": 16,
        "subtitleFontSize": 11
    },
    "width": "container",
    "height": 400,
    "layer": [
        {
            "data": {
                "url": "https://api.data.gov.my/data-catalogue?id=crime_district&limit=10000",
                "format": {
                    "type": "json"
                }
            },
            "transform": [
                {
                    "calculate": "toNumber(datum.crimes)",
                    "as": "crimes_num"
                },
                {
                    "filter": "datum.type !== 'all'"
                },
                {
                    "calculate": "datum.type === 'robbery_gang_armed' || datum.type === 'robbery_gang_unarmed' || datum.type === 'robbery_solo_armed' || datum.type === 'robbery_solo_unarmed' ? 'Robbery' : datum.type === 'theft_vehicle_lorry' || datum.type === 'theft_vehicle_motorcar' || datum.type === 'theft_vehicle_motorcycle' ? 'Vehicle Theft' : datum.type === 'murder' ? 'Murder' : datum.type === 'rape' ? 'Rape' : datum.type === 'break_in' ? 'Break In' : datum.type === 'causing_injury' ? 'Causing Injury' : datum.type === 'theft_other' ? 'Other Theft' : datum.type",
                    "as": "crime_label"
                },
                {
                    "aggregate": [
                        {
                            "op": "sum",
                            "field": "crimes_num",
                            "as": "total_crimes"
                        }
                    ],
                    "groupby": [
                        "crime_label"
                    ]
                }
            ],
            "mark": {
                "type": "arc",
                "tooltip": true
            },
            "encoding": {
                "theta": {
                    "field": "total_crimes",
                    "type": "quantitative"
                },
                "order": {
                    "field": "total_crimes",
                    "type": "quantitative",
                    "sort": "ascending"
                },
                "color": {
                    "field": "crime_label",
                    "type": "nominal",
                    "legend": {
                        "title": "Crime Type"
                    },
                    "scale": {
                        "domain": [
                            "Vehicle Theft",
                            "Robbery",
                            "Murder",
                            "Rape",
                            "Break In",
                            "Causing Injury",
                            "Other Theft"
                        ],
                        "range": [
                            "#4E79A7",
                            "#F28E2B",
                            "#E15759",
                            "#EDC948",
                            "#B07AA1",
                            "#3A86FF",
                            "#B7B7A4"
                        ]
                    }
                },
                "tooltip": [
                    {
                        "field": "crime_label",
                        "type": "nominal",
                        "title": "Crime Type"
                    },
                    {
                        "field": "total_crimes",
                        "type": "quantitative",
                        "title": "Total Crimes",
                        "format": ","
                    }
                ]
            }
        },
        {
            "data": {
                "values": [
                    { "label": "0.41%", "x": 430, "y": 50, "x2": 100, "y2": 50, "color": "#E15759" },
                    { "label": "36.57%", "x": 320, "y": 150, "x2": 100, "y2": 150, "color": "#4E79A7" },
                    { "label": "24.22%", "x": 400, "y": 300, "x2": 100, "y2": 300, "color": "#B7B7A4" },
                    { "label": "2.29%", "x": 440, "y": 30, "x2": 700, "y2": 30, "color": "#EDC948" },
                    { "label": "5.88%", "x": 470, "y": 70, "x2": 700, "y2": 70, "color": "#3A86FF" },
                    { "label": "11.68%", "x": 550, "y": 150, "x2": 700, "y2": 200, "color": "#F28E2B" },
                    { "label": "18.95%", "x": 530, "y": 250, "x2": 700, "y2": 300, "color": "#B07AA1" }
                ]
            },

            "layer": [
                {
                "mark": {
                    "type": "rule",
                    "opacity": 0.3
                },
                "encoding": {
                    "x": {
                        "field": "x",
                        "type": "quantitative",
                        "scale": null,
                        "axis": null
                    },
                    "y": {
                        "field": "y",
                        "type": "quantitative",
                        "scale": null,
                        "axis": null
                    },
                    "x2": {
                        "field": "x2"
                    },
                    "y2": {
                        "field": "y2"
                    }
                }
                },
                {
                "mark": {
                    "type": "text",
                    "baseline": "line-bottom",
                    "align": "left",
                    "fontSize": 20
                },
                "encoding": {
                    "x": {
                    "field": "x2",
                    "scale": null,
                    "axis": null
                    },
                    "y": {
                    "field": "y2",
                    "scale": null,
                    "axis": null
                    },
                    "text": { "field": "label" },
                    "color": { "field": "color", "type": "nominal", "scale": null }
                }
                }
            ]
        }
    ]
}