{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 700,
  "height": 450,
  "padding": 5,
  "autosize": "none",

  "data": [
    {
      "name": "source",
      "values": [
        {"id": "root",             "parent": null,           "name": "All Crimes",      "crimes": 0},
        {"id": "Break in",         "parent": "root",         "name": "Break in",        "crimes": 114734},
        {"id": "Causing injury",   "parent": "root",         "name": "Causing Injury",  "crimes": 35608},
        {"id": "Murder",           "parent": "root",         "name": "Murder",          "crimes": 2462},
        {"id": "Other theft",      "parent": "root",         "name": "Other Theft",     "crimes": 146660},
        {"id": "Rape",             "parent": "root",         "name": "Rape",            "crimes": 13868},
        {"id": "Robbery",          "parent": "root",         "name": "Robbery",         "crimes": 0},
        {"id": "Gang Armed",       "parent": "Robbery",      "name": "Gang Armed",      "crimes": 205},
        {"id": "Gang Unarmed",     "parent": "Robbery",      "name": "Gang Unarmed",    "crimes": 44360},
        {"id": "Solo Armed",       "parent": "Robbery",      "name": "Solo Armed",      "crimes": 67},
        {"id": "Solo Unarmed",     "parent": "Robbery",      "name": "Solo Unarmed",    "crimes": 26089},
        {"id": "Vehicle theft",    "parent": "root",         "name": "Vehicle Theft",   "crimes": 0},
        {"id": "Lorry Theft",      "parent": "Vehicle theft","name": "Lorry Theft",     "crimes": 11504},
        {"id": "Motorcar Theft",   "parent": "Vehicle theft","name": "Motorcar Theft",  "crimes": 47281},
        {"id": "Motorcycle Theft", "parent": "Vehicle theft","name": "Motorcycle Theft","crimes": 162659}
      ]
    },
    {
      "name": "tree",
      "source": "source",
      "transform": [
        {
          "type": "stratify",
          "key": "id",
          "parentKey": "parent"
        },
        {
          "type": "treemap",
          "field": "crimes",
          "sort": {"field": "value", "order": "descending"},
          "round": true,
          "method": "squarify",
          "ratio": 1.618,
          "size": [{"signal": "width"}, {"signal": "height"}]
        }
      ]
    },
    {
      "name": "nodes",
      "source": "tree",
      "transform": [
        {"type": "filter", "expr": "datum.children && datum.depth > 0"}
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [
        {"type": "filter", "expr": "!datum.children && datum.depth > 0"}
      ]
    }
  ],

  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": ["Break in", "Causing injury", "Murder", "Other theft", "Rape", "Robbery", "Vehicle theft"],
      "range": ["#534AB7", "#0F6E56", "#993C1D", "#185FA5", "#993556", "#BA7517", "#3B6D11"]
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "nodes"},
      "interactive": false,
      "encode": {
        "enter": {
          "stroke": {"value": "#ffffff"},
          "strokeWidth": {"value": 2}
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "id"},
          "opacity": {"value": 0.3}
        }
      }
    },
    {
      "type": "rect",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {
          "stroke": {"value": "#ffffff"},
          "strokeWidth": {"value": 1.5},
          "tooltip": {
            "signal": "{'Category': datum.parent === 'root' ? datum.name : datum.parent, 'Type': datum.name, 'Crimes': format(datum.crimes, ',')}"
          }
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {
            "signal": "datum.parent === 'root' ? scale('color', datum.id) : scale('color', datum.parent)"
          },
          "opacity": {"value": 0.85}
        },
        "hover": {
          "opacity": {"value": 1},
          "strokeWidth": {"value": 2.5}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "fill": {"value": "#ffffff"},
          "font": {"value": "sans-serif"},
          "fillOpacity": {"value": 0.95}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "0.5 * (datum.y0 + datum.y1) - 7"},
          "text": {
            "signal": "(datum.x1 - datum.x0) > 55 && (datum.y1 - datum.y0) > 28 ? datum.name : ''"
          },
          "fontSize": {
            "signal": "clamp((datum.x1 - datum.x0) / 8, 9, 13)"
          },
          "fontWeight": {"value": "600"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "fill": {"value": "#ffffff"},
          "font": {"value": "sans-serif"},
          "fillOpacity": {"value": 0.8}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "0.5 * (datum.y0 + datum.y1) + 9"},
          "text": {
            "signal": "(datum.x1 - datum.x0) > 65 && (datum.y1 - datum.y0) > 44 ? format(datum.crimes, ',') : ''"
          },
          "fontSize": {"value": 10},
          "fontWeight": {"value": "400"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "nodes"},
      "interactive": false,
      "encode": {
        "enter": {
          "align": {"value": "center"},
          "baseline": {"value": "top"},
          "fill": {"value": "#ffffff"},
          "font": {"value": "sans-serif"},
          "fontWeight": {"value": "700"},
          "fillOpacity": {"value": 0.9}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "datum.y0 + 5"},
          "text": {
            "signal": "(datum.x1 - datum.x0) > 40 ? datum.name : ''"
          },
          "fontSize": {"value": 11}
        }
      }
    }
  ]
}