{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Malaysia Crimes by Type",
        "fontSize": 16,
        "subtitleFontSize": 11
    },
    "width": "container",
    "height": 300,
    "data": {
        "url": "https://api.data.gov.my/data-catalogue?id=crime_district&limit=10000",
        "format": {
            "type": "json"
        }
    },
    "transform": [
        {
            "calculate": "toNumber(datum.crimes)",
            "as": "crimes_num"
        },
        {
            "filter": "datum.type !== 'all'"
        },
        {
            "calculate": "datum.type === 'robbery_gang_armed' || datum.type === 'robbery_gang_unarmed' || datum.type === 'robbery_solo_armed' || datum.type === 'robbery_solo_unarmed' ? 'Robbery' : datum.type === 'theft_vehicle_lorry' || datum.type === 'theft_vehicle_motorcar' || datum.type === 'theft_vehicle_motorcycle' ? 'Vehicle Theft' : datum.type === 'murder' ? 'Murder' : datum.type === 'rape' ? 'Rape' : datum.type === 'break_in' ? 'Break In' : datum.type === 'causing_injury' ? 'Causing Injury' : datum.type === 'theft_other' ? 'Other Theft' : datum.type",
            "as": "crime_label"
        },
        {
            "aggregate": [
                {
                    "op": "sum",
                    "field": "crimes_num",
                    "as": "total_crimes"
                }
            ],
            "groupby": [
                "crime_label"
            ]
        }
    ],
    "mark": {
        "type": "arc",
        "tooltip": true
    },
    "encoding": {
        "theta": {
            "field": "total_crimes",
            "type": "quantitative"
        },
        "order": {
            "field": "total_crimes",
            "type": "quantitative",
            "sort": "ascending"
        },
        "color": {
            "field": "crime_label",
            "type": "nominal",
            "legend": {
                "title": "Crime Type"
            },
            "scale": {
                "domain": [
                    "Vehicle Theft",
                    "Robbery",
                    "Murder",
                    "Rape",
                    "Break In",
                    "Causing Injury",
                    "Other Theft"
                ],
                "range": [
                    "#FF2E63",
                    "#0057FF",
                    "#7B00FF",
                    "#FF6A00",
                    "#00C2FF",
                    "#A0522D",
                    "#FF85A1"
                ]
            }
        },
        "tooltip": [
            {
                "field": "crime_label",
                "type": "nominal",
                "title": "Crime Type"
            },
            {
                "field": "total_crimes",
                "type": "quantitative",
                "title": "Total Crimes",
                "format": ","
            }
        ]
    }
}