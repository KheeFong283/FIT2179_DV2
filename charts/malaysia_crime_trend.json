{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Malaysia's Crimes Over Time",
        "fontSize": 18,
        "subtitleFontSize": 12
    },
    "width": "container",
    "height": 400,
    "data": {
        "url": "../data/malaysia_crime_trend.csv",
        "format": {
            "type": "csv"
        }
    },
    "mark": "line",
    "encoding": {
        "x": {
            "field": "year",
            "type": "temporal",
            "title": "Year",
            "axis": {
                "format": "%Y",
                "tickCount": "year"
            }
        },
        "y": {
            "field": "crimes",
            "type": "quantitative",
            "axis": {
                "title": "Total Crimes"
            }
        },
        "tooltip": [
            {
                "field": "year",
                "type": "temporal",
                "title": "Year"
            },
            {
                "field": "crimes",
                "type": "quantitative",
                "title": "Total Crimes",
                "format": ","
            }
        ]
    }
}